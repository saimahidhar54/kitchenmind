<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="KitchenMind — Smart Inventory Management & Zero-Waste Recipe Engine. Track your kitchen ingredients, get expiry alerts, and discover recipes.">
  <title><%= title %> — Smart Kitchen Inventory</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- ─── NAVBAR ─────────────────────────────────────────────── -->
  <nav class="navbar navbar-expand-lg sticky-top glass-nav">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <span class="brand-icon">🍳</span>
        <span class="brand-text">Kitchen<span class="text-accent">Mind</span></span>
      </a>
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-rescue pulse-glow" id="btnRescue" onclick="showRescue()">
          <i class="bi bi-exclamation-triangle-fill"></i> Rescue My Food
        </button>
        <button class="btn btn-add-ingredient" onclick="openAddModal()">
          <i class="bi bi-plus-lg"></i> Add Ingredient
        </button>
      </div>
    </div>
  </nav>

  <!-- ─── HERO STATS ──────────────────────────────────────────── -->
  <section class="hero-section">
    <div class="container">
      <div class="row g-4" id="statsRow">
        <div class="col-md-3 col-6">
          <div class="stat-card glass-card">
            <div class="stat-icon stat-total"><i class="bi bi-box-seam-fill"></i></div>
            <div class="stat-value" id="statTotal">0</div>
            <div class="stat-label">Total Items</div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="stat-card glass-card">
            <div class="stat-icon stat-fresh"><i class="bi bi-check-circle-fill"></i></div>
            <div class="stat-value" id="statFresh">0</div>
            <div class="stat-label">Fresh</div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="stat-card glass-card">
            <div class="stat-icon stat-warning"><i class="bi bi-clock-fill"></i></div>
            <div class="stat-value" id="statWarning">0</div>
            <div class="stat-label">Use Soon</div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="stat-card glass-card">
            <div class="stat-icon stat-urgent"><i class="bi bi-fire"></i></div>
            <div class="stat-value" id="statUrgent">0</div>
            <div class="stat-label">Urgent</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SEARCH & FILTER BAR ──────────────────────────────────── -->
  <section class="container my-4">
    <div class="row g-3 align-items-center">
      <div class="col-md-6">
        <div class="search-box glass-card">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" class="form-control" placeholder="Search ingredients..." oninput="filterIngredients()">
        </div>
      </div>
      <div class="col-md-3">
        <select id="categoryFilter" class="form-select glass-select" onchange="filterIngredients()">
          <option value="">All Categories</option>
          <option value="Dairy">🥛 Dairy</option>
          <option value="Vegetables">🥬 Vegetables</option>
          <option value="Fruits">🍎 Fruits</option>
          <option value="Meat">🍗 Meat</option>
          <option value="Grains">🌾 Grains</option>
          <option value="Bakery">🍞 Bakery</option>
          <option value="Spices">🌶️ Spices</option>
          <option value="Beverages">🥤 Beverages</option>
          <option value="Other">📦 Other</option>
        </select>
      </div>
      <div class="col-md-3">
        <select id="sortFilter" class="form-select glass-select" onchange="filterIngredients()">
          <option value="expiry">Sort by Expiry (Soonest)</option>
          <option value="name">Sort by Name (A–Z)</option>
          <option value="category">Sort by Category</option>
          <option value="quantity">Sort by Quantity</option>
        </select>
      </div>
    </div>
  </section>

  <!-- ─── MAIN INGREDIENT GRID ────────────────────────────────── -->
  <main class="container mb-5">
    <div class="section-header d-flex justify-content-between align-items-center mb-3">
      <h2 class="section-title"><i class="bi bi-grid-3x3-gap-fill"></i> My Inventory</h2>
      <span class="badge bg-secondary" id="itemCount">0 items</span>
    </div>
    <div class="row g-4" id="ingredientGrid">
      <!-- Cards injected by JS -->
    </div>
    <div class="empty-state d-none" id="emptyState">
      <div class="empty-icon">🧊</div>
      <h4>Your kitchen is empty!</h4>
      <p class="text-muted">Add your first ingredient to get started</p>
      <button class="btn btn-add-ingredient" onclick="openAddModal()">
        <i class="bi bi-plus-lg"></i> Add Ingredient
      </button>
    </div>
  </main>

  <!-- ─── RESCUE MY FOOD SECTION (hidden by default) ─────────── -->
  <section class="container mb-5 d-none" id="rescueSection">
    <div class="rescue-banner glass-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Rescue My Food!</h2>
        <button class="btn btn-sm btn-outline-light" onclick="hideRescue()"><i class="bi bi-x-lg"></i> Close</button>
      </div>
      <p class="text-muted mb-4">These ingredients are expiring soon — use them before it's too late!</p>
      <div class="row g-4" id="rescueGrid">
        <!-- Rescue cards injected by JS -->
      </div>
    </div>
  </section>

  <!-- ─── RECIPE SUGGESTIONS ──────────────────────────────────── -->
  <section class="container mb-5">
    <div class="section-header d-flex justify-content-between align-items-center mb-3">
      <h2 class="section-title"><i class="bi bi-book-fill"></i> Recipe Suggestions</h2>
      <button class="btn btn-sm btn-outline-light" onclick="fetchRecipes()" id="btnRefreshRecipes">
        <i class="bi bi-arrow-clockwise"></i> Refresh
      </button>
    </div>
    <p class="text-muted mb-3">Based on your ingredients, here are some recipes you can try:</p>
    <div class="row g-4" id="recipeGrid">
      <!-- Recipe cards injected by JS -->
    </div>
    <div class="text-center mt-3 d-none" id="recipeLoading">
      <div class="spinner-border text-accent" role="status">
        <span class="visually-hidden">Loading recipes...</span>
      </div>
    </div>
  </section>

  <!-- ─── FOOTER ──────────────────────────────────────────────── -->
  <footer class="glass-footer text-center py-4">
    <div class="container">
      <p class="mb-1">🍳 <strong>KitchenMind</strong> — Smart Inventory & Zero-Waste Recipe Engine</p>
      <small class="text-muted">Sai Mahidhar (25MCMT29) & Shaik Jani Begum (25MCMT09) • M.Tech CS • SE Lab 2025–26</small>
    </div>
  </footer>

  <!-- ─── ADD / EDIT INGREDIENT MODAL ────────────────────────── -->
  <div class="modal fade" id="ingredientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-modal">
        <div class="modal-header border-0">
          <h5 class="modal-title" id="modalTitle">
            <i class="bi bi-plus-circle-fill text-accent"></i> Add Ingredient
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="ingredientForm">
            <input type="hidden" id="ingredientId">
            <div class="mb-3">
              <label for="ingredientName" class="form-label">Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="ingredientName" placeholder="e.g. Tomatoes" required>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-6">
                <label for="ingredientQty" class="form-label">Quantity <span class="text-danger">*</span></label>
                <input type="number" class="form-control" id="ingredientQty" placeholder="e.g. 5" min="0.01" step="any" required>
              </div>
              <div class="col-6">
                <label for="ingredientUnit" class="form-label">Unit <span class="text-danger">*</span></label>
                <select class="form-select" id="ingredientUnit" required>
                  <option value="pcs">pcs</option>
                  <option value="kg">kg</option>
                  <option value="grams">grams</option>
                  <option value="litre">litre</option>
                  <option value="ml">ml</option>
                  <option value="cups">cups</option>
                  <option value="loaf">loaf</option>
                  <option value="dozen">dozen</option>
                  <option value="pack">pack</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label for="ingredientCategory" class="form-label">Category <span class="text-danger">*</span></label>
              <select class="form-select" id="ingredientCategory" required>
                <option value="Dairy">🥛 Dairy</option>
                <option value="Vegetables">🥬 Vegetables</option>
                <option value="Fruits">🍎 Fruits</option>
                <option value="Meat">🍗 Meat</option>
                <option value="Grains">🌾 Grains</option>
                <option value="Bakery">🍞 Bakery</option>
                <option value="Spices">🌶️ Spices</option>
                <option value="Beverages">🥤 Beverages</option>
                <option value="Other">📦 Other</option>
              </select>
            </div>
            <div class="mb-3">
              <label for="ingredientExpiry" class="form-label">Expiry Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="ingredientExpiry" required>
            </div>
            <div class="mb-3">
              <label for="ingredientNotes" class="form-label">Notes</label>
              <input type="text" class="form-control" id="ingredientNotes" placeholder="Optional notes...">
            </div>
          </form>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-accent" id="btnSave" onclick="saveIngredient()">
            <i class="bi bi-check-lg"></i> Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── DELETE CONFIRMATION MODAL ──────────────────────────── -->
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content glass-modal">
        <div class="modal-header border-0">
          <h5 class="modal-title text-danger"><i class="bi bi-trash3-fill"></i> Delete Ingredient</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p>Are you sure you want to delete <strong id="deleteName"></strong>?</p>
          <p class="text-muted small">This action cannot be undone.</p>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger btn-sm" id="btnConfirmDelete" onclick="confirmDelete()">
            <i class="bi bi-trash3"></i> Delete
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── TOAST NOTIFICATION ─────────────────────────────────── -->
  <div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="appToast" class="toast align-items-center border-0" role="alert">
      <div class="d-flex">
        <div class="toast-body" id="toastBody"></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg sticky-top glass-nav">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <span class="brand-icon">🍳</span>
        <span class="brand-text">Kitchen<span class="text-accent">Mind</span></span>
      </a>
      <div class="d-flex gap-2">
        <a href="/login" class="btn btn-outline-light">Login</a>
        <a href="/register" class="btn btn-accent">Get Started</a>
      </div>
    </div>
  </nav>

  <section class="hero-section" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container text-center">
      <h1 class="display-3 fw-bold mb-4">Smart Kitchen Management<br>Made <span class="text-accent">Simple</span></h1>
      <p class="lead text-muted mb-5">Track ingredients, reduce waste, plan meals, and discover personalized recipes based on your dietary needs.</p>
      <div class="d-flex gap-3 justify-content-center">
        <a href="/register" class="btn btn-accent btn-lg"><i class="bi bi-rocket-takeoff"></i> Start Free</a>
        <a href="/login" class="btn btn-outline-light btn-lg"><i class="bi bi-box-arrow-in-right"></i> Login</a>
      </div>

      <div class="row g-4 mt-5">
        <div class="col-md-3">
          <div class="glass-card p-4">
            <div class="stat-icon stat-total mb-3"><i class="bi bi-person-check-fill"></i></div>
            <h5>User Profiles</h5>
            <p class="text-muted small">Personalized nutrition goals & allergies</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="glass-card p-4">
            <div class="stat-icon stat-fresh mb-3"><i class="bi bi-calendar-check-fill"></i></div>
            <h5>Meal Planning</h5>
            <p class="text-muted small">Plan your weekly meals effortlessly</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="glass-card p-4">
            <div class="stat-icon stat-warning mb-3"><i class="bi bi-cart-fill"></i></div>
            <h5>Smart Shopping</h5>
            <p class="text-muted small">Auto-generated shopping lists</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="glass-card p-4">
            <div class="stat-icon stat-urgent mb-3"><i class="bi bi-book-fill"></i></div>
            <h5>Custom Recipes</h5>
            <p class="text-muted small">Recipes tailored to your needs</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="glass-footer text-center py-4">
    <div class="container">
      <p class="mb-1">🍳 <strong>KitchenMind</strong> — Smart Inventory & Zero-Waste Recipe Engine</p>
      <small class="text-muted">Sai Mahidhar (25MCMT29) & Shaik Jani Begum (25MCMT09) • M.Tech CS • SE Lab 2025–26</small>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

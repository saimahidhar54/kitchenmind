<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - KitchenMind</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- ─── NAVBAR ─────────────────────────────────────────────── -->
  <nav class="navbar navbar-expand-lg sticky-top glass-nav">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/dashboard">
        <span class="brand-icon">🍳</span>
        <span class="brand-text">Kitchen<span class="text-accent">Mind</span></span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center gap-2">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard"><i class="bi bi-house-fill"></i> Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/profile"><i class="bi bi-person-fill"></i> Profile</a>
          </li>
          <li class="nav-item">
            <span class="text-muted small">Hi, <%= username %>!</span>
          </li>
          <li class="nav-item">
            <a href="/logout" class="btn btn-outline-light btn-sm">
              <i class="bi bi-box-arrow-right"></i> Logout
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container my-5">
    <div class="row">
      <div class="col-lg-8 offset-lg-2">
        <div class="glass-card p-4 mb-4">
          <h2 class="section-title mb-4"><i class="bi bi-person-circle"></i> My Profile</h2>

          <% if (error && error.length > 0) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>
          <% if (success && success.length > 0) { %>
            <div class="alert alert-success"><%= success %></div>
          <% } %>

          <div class="mb-4">
            <h5>Account Information</h5>
            <p><strong>Username:</strong> <%= user.username %></p>
            <p><strong>Email:</strong> <%= user.email %></p>
            <p class="text-muted small">Member since <%= new Date(user.created_at).toLocaleDateString() %></p>
          </div>

          <hr class="my-4">

          <form action="/profile/update" method="POST">
            <h5 class="mb-3"><i class="bi bi-heart-pulse-fill text-danger"></i> Nutritional Goals (Daily)</h5>
            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label for="daily_calories" class="form-label">Calories (kcal)</label>
                <input type="number" class="form-control" id="daily_calories" name="daily_calories" 
                       value="<%= profile.daily_calories || 2000 %>" min="1000" max="5000">
              </div>
              <div class="col-md-6">
                <label for="daily_protein" class="form-label">Protein (g)</label>
                <input type="number" class="form-control" id="daily_protein" name="daily_protein" 
                       value="<%= profile.daily_protein || 50 %>" min="0" max="500">
              </div>
              <div class="col-md-6">
                <label for="daily_carbs" class="form-label">Carbohydrates (g)</label>
                <input type="number" class="form-control" id="daily_carbs" name="daily_carbs" 
                       value="<%= profile.daily_carbs || 250 %>" min="0" max="1000">
              </div>
              <div class="col-md-6">
                <label for="daily_fat" class="form-label">Fat (g)</label>
                <input type="number" class="form-control" id="daily_fat" name="daily_fat" 
                       value="<%= profile.daily_fat || 70 %>" min="0" max="500">
              </div>
            </div>

            <h5 class="mb-3"><i class="bi bi-people-fill text-info"></i> Serving Preferences</h5>
            <div class="mb-4">
              <label for="serving_size" class="form-label">Number of People Cooking For</label>
              <input type="number" class="form-control" id="serving_size" name="serving_size" 
                     value="<%= profile.serving_size || 1 %>" min="1" max="20">
              <small class="text-muted">Recipes will be scaled to this serving size</small>
            </div>

            <h5 class="mb-3"><i class="bi bi-shield-fill-exclamation text-warning"></i> Dietary Restrictions</h5>
            <div class="mb-3">
              <label for="allergies" class="form-label">Allergies (comma-separated)</label>
              <input type="text" class="form-control" id="allergies" name="allergies" 
                     value="<%= profile.allergies || '' %>" 
                     placeholder="e.g., peanuts, shellfish, dairy">
              <small class="text-muted">Recipes containing these ingredients will be filtered out</small>
            </div>

            <div class="mb-4">
              <label for="dietary_preference" class="form-label">Dietary Preference</label>
              <select class="form-select" id="dietary_preference" name="dietary_preference">
                <option value="" <%= !profile.dietary_preference ? 'selected' : '' %>>No Preference</option>
                <option value="vegetarian" <%= profile.dietary_preference === 'vegetarian' ? 'selected' : '' %>>Vegetarian</option>
                <option value="vegan" <%= profile.dietary_preference === 'vegan' ? 'selected' : '' %>>Vegan</option>
                <option value="pescatarian" <%= profile.dietary_preference === 'pescatarian' ? 'selected' : '' %>>Pescatarian</option>
                <option value="keto" <%= profile.dietary_preference === 'keto' ? 'selected' : '' %>>Keto</option>
                <option value="paleo" <%= profile.dietary_preference === 'paleo' ? 'selected' : '' %>>Paleo</option>
                <option value="gluten-free" <%= profile.dietary_preference === 'gluten-free' ? 'selected' : '' %>>Gluten-Free</option>
              </select>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-accent">
                <i class="bi bi-check-lg"></i> Save Changes
              </button>
              <a href="/dashboard" class="btn btn-secondary">
                <i class="bi bi-x-lg"></i> Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <footer class="glass-footer text-center py-4">
    <div class="container">
      <p class="mb-1">🍳 <strong>KitchenMind</strong> — Smart Inventory & Zero-Waste Recipe Engine</p>
      <small class="text-muted">Sai Mahidhar (25MCMT29) & Shaik Jani Begum (25MCMT09) • M.Tech CS • SE Lab 2025–26</small>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
